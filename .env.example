# ntfy.sh topic name (pick something hard to guess, e.g. plant-monitor-abc123)
NTFY_TOPIC=plant-monitor-your-topic-here

# Gmail address to send FROM
EMAIL_FROM=youraddress@gmail.com

# Address to receive alerts
EMAIL_TO=youraddress@gmail.com

# Gmail App Password — create at https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Set to 'true' to enable keyword/family blocklist filtering
FILTERS_ENABLED=false
